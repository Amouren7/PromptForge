# Prompt Optimizer - API 配置
# 复制此文件为 .env 并填入你的 API Key

# OpenAI / OpenAI 兼容接口
VITE_OPENAI_API_KEY=sk-your-key-here
VITE_OPENAI_MODEL=gpt-5.5

# Google Gemini
VITE_GEMINI_API_KEY=your-gemini-key-here

# Anthropic Claude
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# DeepSeek
VITE_DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Grok (xAI)
VITE_GROK_API_KEY=your-grok-key-here

# 智谱
VITE_ZHIPU_API_KEY=your-zhipu-key-here

# SiliconFlow
VITE_SILICONFLOW_API_KEY=your-siliconflow-key-here

# --- 自定义 OpenAI 兼容提供商 ---
# 支持多个自定义，用后缀区分，例如：
# VITE_CUSTOM_API_KEY_MYPROVIDER=sk-xxx
# VITE_CUSTOM_API_BASE_URL_MYPROVIDER=https://api.example.com/v1
# VITE_CUSTOM_API_MODEL_MYPROVIDER=gpt-4o
